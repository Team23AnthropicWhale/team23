{
  "form_id": "1B",
  "title": "Registration and Rapid Assessment Form",
  "sections": [
    {
      "id": "case_info",
      "title": "Case Information",
      "fields": [
        { "id": "date_identified", "label": "Date case was identified", "type": "date" },
        { "id": "date_registered", "label": "Date case was registered", "type": "date" },
        { "id": "date_reopened", "label": "Date case was re-opened", "type": "date", "optional": true },
        { "id": "case_id", "label": "Case ID", "type": "string" },
        { "id": "caseworker_id", "label": "Caseworker ID", "type": "string" },
        { "id": "agency", "label": "Agency", "type": "string" },
        {
          "id": "identification_source",
          "label": "How was the child identified",
          "type": "enum",
          "options": [
            "self_referral",
            "family_member",
            "community_member",
            "media",
            "other_service_provider",
            "un_ingo_ngo"
          ]
        },
        { "id": "identification_source_sector", "label": "Sector (if service provider or UN/INGO/NGO)", "type": "enum", "optional": true, "options": ["education", "food_security", "health", "livelihoods", "nutrition", "protection", "child_protection", "gbv", "shelter", "camp_coordination", "wash", "other"] },
        { "id": "identification_source_other", "label": "Other sector specification", "type": "string", "optional": true }
      ]
    },
    {
      "id": "child_personal",
      "title": "Child Personal Details",
      "fields": [
        { "id": "first_name", "label": "First name", "type": "string" },
        { "id": "middle_name", "label": "Middle name / Father's name", "type": "string", "optional": true },
        { "id": "last_name", "label": "Last name / Family name", "type": "string" },
        { "id": "other_names", "label": "Other names or spelling", "type": "string", "optional": true },
        { "id": "dob", "label": "Date of birth", "type": "date" },
        { "id": "age", "label": "Age", "type": "integer" },
        { "id": "age_estimated", "label": "Is age estimated", "type": "boolean" },
        { "id": "sex", "label": "Sex", "type": "enum", "options": ["male", "female", "non_binary", "other"] },
        { "id": "birth_registration", "label": "Birth registration status", "type": "enum", "options": ["registered", "not_registered", "in_progress"] },
        { "id": "has_id", "label": "Does child have ID", "type": "boolean" },
        { "id": "id_type", "label": "ID type", "type": "string", "optional": true, "conditional": { "field": "has_id", "value": true } },
        { "id": "id_number", "label": "ID number", "type": "string", "optional": true, "conditional": { "field": "has_id", "value": true } },
        { "id": "nationality_status", "label": "Nationality status", "type": "enum", "options": ["national", "other_nationality", "stateless", "unknown"] },
        { "id": "displacement_status", "label": "Displacement status", "type": "enum", "options": ["host_community", "asylum_seeker_refugee", "idp", "returnee", "migrant", "other"] },
        { "id": "displacement_status_other", "label": "Other displacement status", "type": "string", "optional": true },
        { "id": "nationality", "label": "Nationality", "type": "string" },
        { "id": "disability_status", "label": "Disability status", "type": "enum", "options": ["no_disabilities", "mental_impairment", "sensory_impairment", "physical_impairment", "intellectual_impairment", "other"] },
        { "id": "disability_other", "label": "Other disability", "type": "string", "optional": true },
        { "id": "marital_status", "label": "Marital status", "type": "enum", "options": ["not_married", "planning_to_marry", "married", "divorced", "widowed"] },
        { "id": "ethnic_affiliation", "label": "Ethnic affiliation", "type": "string", "optional": true },
        { "id": "religion", "label": "Religion", "type": "string", "optional": true },
        { "id": "languages_spoken", "label": "Languages spoken", "type": "array", "items": "string" }
      ]
    },
    {
      "id": "care_arrangement",
      "title": "Child Current Care / Living Arrangements",
      "fields": [
        {
          "id": "care_type",
          "label": "Type of care arrangement",
          "type": "enum",
          "options": [
            "parental_care", "no_care", "child_carer", "child_headed_household",
            "institutional_care", "foster_care", "kinship_care", "other_family_based",
            "supported_independent", "other"
          ]
        },
        { "id": "care_type_other", "label": "Other care type", "type": "string", "optional": true },
        { "id": "care_description", "label": "Description of care arrangement", "type": "text" },
        { "id": "current_address", "label": "Current address", "type": "text" },
        { "id": "area_type", "label": "Area of living", "type": "enum", "optional": true, "options": ["urban_non_camp", "rural_non_camp", "camp_settlement", "other"] },
        { "id": "contact_method", "label": "How can the child be contacted", "type": "text" }
      ]
    },
    {
      "id": "caregiver",
      "title": "Caregiver Details",
      "note": "Fill if child is not cared for by one or both parents",
      "fields": [
        { "id": "caregiver_first_name", "label": "First name", "type": "string" },
        { "id": "caregiver_middle_name", "label": "Middle name / Father's name", "type": "string", "optional": true },
        { "id": "caregiver_last_name", "label": "Last name / Family name", "type": "string" },
        { "id": "caregiver_dob", "label": "Date of birth", "type": "date" },
        { "id": "caregiver_age", "label": "Age", "type": "integer" },
        { "id": "caregiver_age_estimated", "label": "Is age estimated", "type": "boolean" },
        { "id": "caregiver_sex", "label": "Sex", "type": "enum", "options": ["male", "female", "non_binary", "other"] },
        { "id": "caregiver_has_id", "label": "Does caregiver have ID", "type": "boolean" },
        { "id": "caregiver_id_type", "label": "ID type", "type": "string", "optional": true },
        { "id": "caregiver_id_number", "label": "ID number", "type": "string", "optional": true },
        { "id": "caregiver_nationality_status", "label": "Nationality status", "type": "enum", "options": ["national", "other_nationality", "stateless", "unknown"] },
        { "id": "caregiver_displacement_status", "label": "Displacement status", "type": "enum", "options": ["host_community", "asylum_seeker_refugee", "idp", "returnee", "migrant", "other"] },
        { "id": "caregiver_has_disabilities", "label": "Does caregiver have disabilities or health issues affecting care", "type": "boolean" },
        { "id": "caregiver_disabilities_detail", "label": "Specify", "type": "text", "optional": true, "conditional": { "field": "caregiver_has_disabilities", "value": true } },
        { "id": "caregiver_related_to_child", "label": "Is caregiver related to child", "type": "boolean" },
        { "id": "caregiver_relationship", "label": "Relationship to child", "type": "string", "optional": true },
        { "id": "caregiver_knows_family", "label": "If not related, does caregiver know child's family", "type": "boolean", "optional": true },
        { "id": "care_arrangement_start", "label": "When did care arrangement start", "type": "date" },
        { "id": "caregiver_willing_to_continue", "label": "Is caregiver willing to continue", "type": "boolean" },
        { "id": "caregiver_unwilling_reason", "label": "If not willing, why", "type": "text", "optional": true },
        { "id": "caregiver_is_legal_guardian", "label": "Is caregiver legal guardian", "type": "boolean" },
        { "id": "caregiver_contact", "label": "Caregiver contact details", "type": "text" }
      ]
    },
    {
      "id": "household_members",
      "title": "Household Members",
      "fields": [
        {
          "id": "members",
          "label": "Members of household",
          "type": "array",
          "items": {
            "type": "object",
            "fields": [
              { "id": "full_name", "label": "Full name", "type": "string" },
              { "id": "age", "label": "Age", "type": "integer" },
              { "id": "relationship", "label": "Relationship to child", "type": "string" }
            ]
          }
        },
        { "id": "household_adults", "label": "Number of adults", "type": "integer" },
        { "id": "household_children", "label": "Number of children", "type": "integer" },
        { "id": "main_caregiver_under_18", "label": "Is main caregiver under 18", "type": "boolean" }
      ]
    },
    {
      "id": "protection_risks",
      "title": "Child Protection Risks",
      "fields": [
        { "id": "situation_description", "label": "Brief description of child's situation", "type": "text" },
        {
          "id": "risks_identified",
          "label": "Child protection risks identified",
          "type": "multiselect",
          "options": [
            "physical_violence", "psychological_violence", "sexual_violence",
            "neglect", "economic_exploitation", "hazardous_labour",
            "sexual_exploitation", "conflict_with_law", "recruitment_armed_forces",
            "unaccompanied", "separated", "child_marriage", "psychological_distress"
          ]
        },
        {
          "id": "justice_system_status",
          "label": "Status in relation to justice system",
          "type": "enum",
          "options": ["no_contact", "victim", "witness", "in_conflict_with_law", "detained"]
        }
      ]
    },
    {
      "id": "family_details",
      "title": "Family Details",
      "fields": [
        { "id": "mother_first_name", "label": "Mother first name", "type": "string" },
        { "id": "mother_middle_name", "label": "Mother middle name", "type": "string", "optional": true },
        { "id": "mother_last_name", "label": "Mother last name", "type": "string" },
        { "id": "mother_alive", "label": "Is mother alive", "type": "enum", "options": ["yes", "no", "unknown"] },
        { "id": "mother_death_note", "label": "If deceased, when and how", "type": "text", "optional": true },
        { "id": "mother_nationality_status", "label": "Mother nationality status", "type": "enum", "options": ["national", "other_nationality", "stateless", "unknown"] },
        { "id": "mother_displacement_status", "label": "Mother displacement status", "type": "enum", "options": ["host_community", "asylum_seeker_refugee", "idp", "returnee", "migrant", "other"] },
        { "id": "mother_has_disabilities", "label": "Mother has disabilities affecting care", "type": "boolean" },
        { "id": "mother_disabilities_detail", "label": "Specify", "type": "text", "optional": true },
        { "id": "mother_in_contact", "label": "Is child in contact with mother", "type": "boolean" },
        { "id": "mother_contact_method", "label": "How to contact mother", "type": "text", "optional": true },
        { "id": "mother_dob", "label": "Mother date of birth", "type": "date" },
        { "id": "mother_age", "label": "Mother age", "type": "integer" },
        { "id": "mother_age_estimated", "label": "Is age estimated", "type": "boolean" },
        { "id": "mother_has_id", "label": "Does mother have ID", "type": "boolean" },
        { "id": "mother_id_type", "label": "ID type", "type": "string", "optional": true },
        { "id": "mother_id_number", "label": "ID number", "type": "string", "optional": true },
        { "id": "father_first_name", "label": "Father first name", "type": "string" },
        { "id": "father_middle_name", "label": "Father middle name", "type": "string", "optional": true },
        { "id": "father_last_name", "label": "Father last name", "type": "string" },
        { "id": "father_alive", "label": "Is father alive", "type": "enum", "options": ["yes", "no", "unknown"] },
        { "id": "father_death_note", "label": "If deceased, when and how", "type": "text", "optional": true },
        { "id": "father_nationality_status", "label": "Father nationality status", "type": "enum", "options": ["national", "other_nationality", "stateless", "unknown"] },
        { "id": "father_displacement_status", "label": "Father displacement status", "type": "enum", "options": ["host_community", "asylum_seeker_refugee", "idp", "returnee", "migrant", "other"] },
        { "id": "father_has_disabilities", "label": "Father has disabilities affecting care", "type": "boolean" },
        { "id": "father_disabilities_detail", "label": "Specify", "type": "text", "optional": true },
        { "id": "father_in_contact", "label": "Is child in contact with father", "type": "boolean" },
        { "id": "father_contact_method", "label": "How to contact father", "type": "text", "optional": true },
        { "id": "father_dob", "label": "Father date of birth", "type": "date" },
        { "id": "father_age", "label": "Father age", "type": "integer" },
        { "id": "father_age_estimated", "label": "Is age estimated", "type": "boolean" },
        { "id": "father_has_id", "label": "Does father have ID", "type": "boolean" },
        { "id": "father_id_type", "label": "ID type", "type": "string", "optional": true },
        { "id": "father_id_number", "label": "ID number", "type": "string", "optional": true },
        {
          "id": "immediate_family_members",
          "label": "Immediate family members",
          "type": "array",
          "items": {
            "type": "object",
            "fields": [
              { "id": "full_name", "label": "Full name", "type": "string" },
              { "id": "age", "label": "Age", "type": "integer" },
              { "id": "relationship", "label": "Relationship to child", "type": "string" },
              { "id": "address", "label": "Address or whereabouts", "type": "string" }
            ]
          }
        }
      ]
    },
    {
      "id": "urgent_needs",
      "title": "Urgent Needs",
      "fields": [
        { "id": "has_urgent_needs", "label": "Are there urgent needs requiring immediate response", "type": "boolean" },
        { "id": "needs_family_tracing", "label": "Does child need family tracing", "type": "boolean" },
        {
          "id": "immediate_needs",
          "label": "Immediate needs",
          "type": "array",
          "items": {
            "type": "object",
            "fields": [
              { "id": "category", "label": "Category", "type": "enum", "options": ["health", "safety", "care", "other"] },
              { "id": "category_other", "label": "Other category", "type": "string", "optional": true },
              { "id": "summary_reasons", "label": "Summary reasons", "type": "text" },
              { "id": "action_taken", "label": "Immediate action taken/to be taken", "type": "text" }
            ]
          }
        }
      ]
    },
    {
      "id": "risk_level",
      "title": "Risk Level",
      "fields": [
        { "id": "risk_level", "label": "Risk level", "type": "enum", "options": ["high", "medium", "low"] },
        { "id": "risk_summary", "label": "Summary of reasons for risk level", "type": "text" }
      ]
    },
    {
      "id": "authorization",
      "title": "Authorization",
      "fields": [
        { "id": "caseworker_name", "label": "Caseworker name", "type": "string" },
        { "id": "caseworker_date", "label": "Date", "type": "date" },
        { "id": "caseworker_signature", "label": "Signature", "type": "signature" }
      ]
    }
  ]
}